# Local backend development defaults
# SQLite is the preferred local mode.

TELITE_DB_BACKEND=sqlite
TELITE_DATABASE_URL=
TELITE_DB_PATH=data/telite_lms.db
TELITE_SQLITE_SOURCE_PATH=telite_lms.db

# ============================================================================
# SECURITY CONFIGURATION (CRITICAL - MUST BE SET IN PRODUCTION)
# ============================================================================

# JWT Authentication Secret (REQUIRED IN PRODUCTION)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
TELITE_AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Password Hashing Salt (REQUIRED IN PRODUCTION)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
TELITE_PASSWORD_SALT=CHANGE_ME_TO_A_LONG_RANDOM_SALT

# JWT Token Expiration
TELITE_ACCESS_TOKEN_HOURS=8
TELITE_REFRESH_TOKEN_DAYS=14

# JWT Algorithm (HS256 recommended)
JWT_ALGORITHM=HS256

# Environment (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# REDIS CONFIGURATION (REQUIRED FOR DISTRIBUTED RATE LIMITING)
# ============================================================================

# Redis Connection
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# COOKIE SECURITY (PRODUCTION SETTINGS)
# ============================================================================

# Cookie Security Flags
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=localhost
TELITE_PLATFORM_DOMAINS=platform.telite.com,localhost,127.0.0.1
COOKIE_HTTPONLY=true

TELITE_APP_URL=http://localhost:3000
TELITE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_NAME=Telite LMS

MOODLE_MODE=mock
MOODLE_URL=http://localhost:8082
MOODLE_INTERNAL_URL=http://localhost:8082
MOODLE_WWWROOT=http://localhost:8082
MOODLE_TOKEN=
MOODLE_TEACHER_ROLE_ID=3
MOODLE_STUDENT_ROLE_ID=5
MOODLE_PARENT_CATEGORY_ID=
MOODLE_PARENT_CATEGORY_NAME=Telite Systems
MOODLE_SYNC_EAGER=false

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Uncomment for Docker/production-style backend PostgreSQL mode
# TELITE_DB_BACKEND=postgres
# TELITE_POSTGRES_HOST=postgres
# TELITE_POSTGRES_PORT=5432
# TELITE_POSTGRES_DB=telite_backend
# TELITE_POSTGRES_USER=telite_backend_user
# TELITE_POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
