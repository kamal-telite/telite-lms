# =============================================================================
# Telite Backend - local backend environment file
# Used when running: uvicorn app.main:app --reload --port 8001
# Keep this in sync with the root .env when needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend database
# -----------------------------------------------------------------------------
TELITE_DB_BACKEND=postgres
TELITE_DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/telite_backend
TELITE_POSTGRES_HOST=localhost
TELITE_POSTGRES_PORT=5432
TELITE_POSTGRES_DB=telite_backend
TELITE_POSTGRES_USER=postgres
TELITE_POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Backend auth / security
# -----------------------------------------------------------------------------
# Generate with: python -c 'import secrets; print(secrets.token_hex(64))'
TELITE_AUTH_SECRET=
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
TELITE_PASSWORD_SALT=
REDIS_ENABLED=false
TELITE_ACCESS_TOKEN_HOURS=8
TELITE_REFRESH_TOKEN_DAYS=14

# -----------------------------------------------------------------------------
# App URLs / CORS
# -----------------------------------------------------------------------------
TELITE_APP_URL=http://localhost:3000
TELITE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# SMTP / email
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_NAME=Telite LMS

# -----------------------------------------------------------------------------
# Moodle integration
# -----------------------------------------------------------------------------
MOODLE_MODE=auto
MOODLE_URL=http://localhost:8082
MOODLE_INTERNAL_URL=http://localhost:8082
MOODLE_WWWROOT=http://localhost:8082
MOODLE_TOKEN=
MOODLE_TEACHER_ROLE_ID=3
MOODLE_STUDENT_ROLE_ID=5
MOODLE_PARENT_CATEGORY_ID=
MOODLE_PARENT_CATEGORY_NAME=Telite Systems

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# -----------------------------------------------------------------------------
# Endpoint rate limits
# -----------------------------------------------------------------------------
TELITE_LOGIN_FAILURE_LIMIT=5
TELITE_LOGIN_FAILURE_WINDOW_SECONDS=300
TELITE_FORGOT_PASSWORD_LIMIT=3
TELITE_FORGOT_PASSWORD_WINDOW_SECONDS=900
TELITE_RESET_PASSWORD_LIMIT=5
TELITE_RESET_PASSWORD_WINDOW_SECONDS=900
TELITE_PLATFORM_ADMIN_INVITE_LIMIT=5
TELITE_PLATFORM_ADMIN_INVITE_WINDOW_SECONDS=600
TELITE_PLATFORM_PASSWORD_RESET_LIMIT=5
TELITE_PLATFORM_PASSWORD_RESET_WINDOW_SECONDS=900
TELITE_PLATFORM_MOODLE_SYNC_ORG_LIMIT=3
TELITE_PLATFORM_MOODLE_SYNC_ORG_WINDOW_SECONDS=600
TELITE_PLATFORM_MOODLE_SYNC_ALL_LIMIT=2
TELITE_PLATFORM_MOODLE_SYNC_ALL_WINDOW_SECONDS=600
TELITE_PLATFORM_ANALYTICS_ALERT_LIMIT=10
TELITE_PLATFORM_ANALYTICS_ALERT_WINDOW_SECONDS=600
TELITE_ENROL_BATCH_APPROVE_LIMIT=5
TELITE_ENROL_BATCH_APPROVE_WINDOW_SECONDS=600
