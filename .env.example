# =============================================================================
# Telite LMS - Docker Compose Environment Variables
# Copy this file to .env at the repository root for Docker Compose.
# telite-backend/.env is only for running the backend directly outside Docker.
# =============================================================================

# PostgreSQL database used by Docker / Moodle
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=55432

# FastAPI backend database selection for Docker
TELITE_DB_BACKEND=postgres
BACKEND_PORT=8001
FRONTEND_PORT=3000

# Backend PostgreSQL settings used by the backend container
TELITE_POSTGRES_DB=telite_backend
TELITE_POSTGRES_USER=telite_backend_user
TELITE_POSTGRES_PASSWORD=

# Moodle application settings
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASSWORD=
MOODLE_WWWROOT=http://localhost:8082
MOODLE_URL=http://localhost:8082
MOODLE_TOKEN=
MOODLE_PORT=8082
MOODLE_MODE=mock

# Redis and asynchronous Moodle sync
REDIS_ENABLED=true
REDIS_PORT=6379
REDIS_PASSWORD=
