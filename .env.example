# =============================================================================
# Telite LMS - Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# PostgreSQL database used by Docker / Moodle
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_PORT=55432

# FastAPI backend database selection
# Use sqlite for file-based local runs, or postgres to use the PostgreSQL service.
TELITE_DB_BACKEND=postgres
BACKEND_PORT=8001
FRONTEND_PORT=3000

# Preferred backend connection option
# Example: postgresql://telite_backend_user:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:55432/telite_backend
TELITE_DATABASE_URL=

# Optional explicit backend PostgreSQL settings when not using TELITE_DATABASE_URL
TELITE_POSTGRES_HOST=postgres
TELITE_POSTGRES_PORT=5432
TELITE_POSTGRES_DB=telite_backend
TELITE_POSTGRES_USER=telite_backend_user
TELITE_POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Optional SQLite source path used by telite-backend/migrate_backend_to_postgres.py
TELITE_SQLITE_SOURCE_PATH=telite-backend/telite_lms.db

# Moodle application settings
# When the backend runs inside Docker, MOODLE_DB_HOST is usually "postgres".
MOODLE_DB_HOST=postgres
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
MOODLE_WWWROOT=http://localhost:8082
MOODLE_INTERNAL_URL=http://moodle
MOODLE_URL=http://localhost:8082
MOODLE_TOKEN=
MOODLE_PORT=8082
MOODLE_MODE=mock

# Phase 5 asynchronous Moodle sync
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
MOODLE_SYNC_EAGER=false

# GitHub Container Registry settings used by the image publish scripts
GHCR_USERNAME=your_github_username
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
